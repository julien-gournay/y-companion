# Campus Companion - Variables d'environnement
# À copier/renommer en .env.local pour personnaliser

# 🌐 Configuration API
REACT_APP_API_BASE_URL=http://localhost:8080
REACT_APP_API_TIMEOUT=30000

# 🔐 Authentification (optionnel)
REACT_APP_AUTH_ENABLED=false
REACT_APP_AUTH_URL=http://localhost:3001/auth

# 📱 Configuration Session
REACT_APP_SESSION_TIMEOUT=3600
REACT_APP_ENABLE_ANALYTICS=false

# 🎨 Configuration UI
REACT_APP_THEME=dark
REACT_APP_SUGGESTIONS_COUNT=4

# 🔔 Notifications (optionnel)
REACT_APP_ENABLE_NOTIFICATIONS=false
REACT_APP_FCM_TOKEN=

# 🧪 Mode développement
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_REQUESTS=true

